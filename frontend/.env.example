# Copia a .env o .env.production y ajusta valores.

# URL del backend (REST + Socket.IO), sin barra final. Obligatorio en APK y en web en producción.
# Ejemplo: https://api.tudominio.com
VITE_BACKEND_URL=

# Solo para despliegue en subruta (GitHub Pages). Debe coincidir con el nombre del repo: /omeClone/
# En desarrollo local déjalo vacío o coméntalo.
# VITE_BASE_PATH=/omeClone/

# Cloudflare Pages / Workers / raíz del dominio: base /
# Usa en terminal: npm run build:cloudflare
# O copia a .env.production: VITE_BASE_PATH=/

# Opcional: correo de soporte para apelaciones (enlace mailto en pantallas de suspensión).
# VITE_SUPPORT_EMAIL=soporte@tudominio.com
