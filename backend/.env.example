# Copiar a .env en desarrollo local.

# Obligatorio en producción (Neon, Render Postgres, Supabase, etc.).
# Ejemplo Neon: postgres://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# JWT — en producción usar valor largo aleatorio (Render puede generarlo en el blueprint).
SECRET_KEY=dev_secret_key_change_in_production

# OAuth — opcional; IDs públicos los expone GET /api/auth/oauth/providers
# Google Cloud Console → Credenciales → ID de cliente OAuth (Web). Varios separados por coma.
GOOGLE_OAUTH_CLIENT_IDS=
